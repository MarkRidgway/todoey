// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Fixed enum for now. To support user-customizable statuses later, replace
// with a Status model (id, name, color, sortOrder) and change Todo.status
// to a statusId FK — Kanban column order would then follow sortOrder.
enum Status {
  TODO
  IN_PROGRESS
  DONE
}

// Mirrors ViewId in components/view-switcher.tsx. Extend both together.
enum View {
  LIST
  KANBAN
  GRID
  MATRIX
}

model List {
  id        String        @id @default(uuid())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  settings  ListSettings?
  todos     Todo[]
  tags      Tag[]
}

// One row per List. Holds only enabledViews for now — add more list-level
// preferences here as they're needed (see Status enum comment above for
// the house style on "fixed for now, extend later").
model ListSettings {
  id           String @id @default(cuid())
  list         List   @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId       String @unique
  enabledViews View[] @default([LIST, KANBAN, GRID, MATRIX])
}

model Todo {
  id          String    @id @default(cuid())
  list        List      @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId      String
  title       String
  description String?
  status      Status    @default(TODO)
  urgent      Boolean   @default(false)
  important   Boolean   @default(false)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tags        TagsOnTodos[]

  @@index([listId])
  @@index([listId, status])
}

model Tag {
  id     String @id @default(cuid())
  list   List   @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId String
  name   String
  color  String // hex, e.g. "#f97316" — used for TagBadge background
  todos  TagsOnTodos[]

  @@unique([listId, name])
  @@index([listId])
}

model TagsOnTodos {
  todo   Todo   @relation(fields: [todoId], references: [id], onDelete: Cascade)
  todoId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([todoId, tagId])
}
